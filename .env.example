# ── Root .env for docker-compose ─────────────────────────────────────────────
# Copy to .env and fill in your values before running docker-compose

# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
DB_NAME=semiconductor_defect_db
DB_USER=semi_user
DB_PASSWORD=semi_password

# Backend
SECRET_KEY=change_me_to_a_very_long_random_string_at_least_32_chars

# Email (optional — leave blank to disable email notifications)
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_FROM=noreply@semiconductor-ai.com
MAIL_SERVER=smtp.gmail.com
