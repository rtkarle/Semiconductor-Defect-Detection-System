# ── Application ──────────────────────────────────────────────
APP_NAME="AI Semiconductor Defect Detection"
APP_VERSION="1.0.0"
DEBUG=False
ENVIRONMENT=production          # development | production

# ── API ──────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=semiconductor_defect_db
DB_USER=root
DB_PASSWORD=your_mysql_password

# ── JWT ──────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_very_long_random_secret_key_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── File Storage ─────────────────────────────────────────────
UPLOAD_DIR=uploads
REPORTS_DIR=reports
MAX_UPLOAD_SIZE_MB=20
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/tiff,image/bmp

# ── AI Model ─────────────────────────────────────────────────
MODEL_WEIGHTS_PATH=../ai_model/weights/defect_model.h5
YOLO_WEIGHTS_PATH=../ai_model/weights/yolov8_defect.pt
CONFIDENCE_THRESHOLD=0.50

# ── Email (SMTP) ─────────────────────────────────────────────
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@semiconductor-ai.com
MAIL_FROM_NAME="Semiconductor AI System"
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_TLS=True
MAIL_SSL=False
